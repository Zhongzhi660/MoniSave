{
  "name": "monisave",
  "displayName": "MoniSave",
  "version": "0.1.1",
  "publisher": "MoniSave",
  "repository": {
    "type": "git",
    "url": "https://github.com/Zhongzhi660/MoniSave"
  },
  "description": "Thinking token optimization: heuristic effort + savings in status bar",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Other"],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:monisave.manage",
    "onCommand:monisave.showSavings",
    "onCommand:monisave.useFullEffortOnce",
    "onCommand:monisave.selectEffortMode",
    "onCommand:monisave.switchLanguage",
    "onCommand:monisave.saveCurrentQaAsKnowledge",
    "onCommand:monisave.searchTeamKnowledge",
    "onCommand:monisave.markAnswerUseful",
    "onCommand:monisave.markAnswerNotUseful",
    "onCommand:monisave.listKnowledgeCards"
  ],
  "main": "./out/extension.js",
  "icon": "logo.png",
  "contributes": {
    "configuration": {
      "title": "MoniSave",
      "properties": {
        "monisave.apiKey": {
          "type": "string",
          "default": "",
          "description": "Anthropic API key for Claude (with extended thinking)"
        },
        "monisave.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable heuristic effort; when off, always use high effort"
        },
        "monisave.effortMode": {
          "type": "string",
          "enum": ["auto", "low", "medium", "high", "max"],
          "default": "auto",
          "description": "Manual effort mode: auto uses heuristics; max is downgraded on unsupported models"
        },
        "monisave.currency": {
          "type": "string",
          "enum": ["usd", "cny"],
          "default": "usd",
          "description": "Currency for savings display"
        },
        "monisave.showDifficulty": {
          "type": "boolean",
          "default": false,
          "description": "Show current difficulty tier (simple/medium/complex) in status bar"
        },
        "monisave.showEffortOnSend": {
          "type": "boolean",
          "default": true,
          "description": "When sending a message, show which effort (low/medium/high) is used for that message. Turn off to reduce status bar messages. / 发送消息时显示本条使用的档位，便于验证切换是否生效"
        },
        "monisave.language": {
          "type": "string",
          "enum": ["en", "zh"],
          "enumDescriptions": ["English", "中文"],
          "default": "en",
          "description": "UI language / 界面语言"
        },
        "monisave.knowledge.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable team knowledge retrieval and reuse"
        },
        "monisave.knowledge.topK": {
          "type": "number",
          "default": 3,
          "minimum": 1,
          "maximum": 10,
          "description": "Maximum number of knowledge cards to retrieve"
        },
        "monisave.knowledge.minScore": {
          "type": "number",
          "default": 0.3,
          "minimum": 0,
          "maximum": 1,
          "description": "Minimum retrieval score for injecting knowledge context"
        },
        "monisave.knowledge.summaryMode": {
          "type": "string",
          "enum": ["off", "cheap", "smart"],
          "default": "off",
          "description": "Knowledge summary mode; off disables model-based summarization"
        },
        "monisave.knowledge.repoPath": {
          "type": "string",
          "default": "",
          "description": "Optional folder path for shared knowledge JSONL files"
        },
        "monisave.knowledge.feedbackWeight": {
          "type": "number",
          "default": 0.25,
          "minimum": 0,
          "maximum": 1,
          "description": "Weight of explicit useful/not useful feedback in ranking"
        },
        "monisave.knowledge.feedbackMinSamples": {
          "type": "number",
          "default": 3,
          "minimum": 1,
          "maximum": 100,
          "description": "Minimum feedback samples before applying full feedback weight"
        }
      }
    },
    "chatParticipants": [
      {
        "id": "monisave.participant",
        "name": "monisave",
        "fullName": "MoniSave",
        "description": "Save/search knowledge, mark answer useful or not",
        "isSticky": false,
        "commands": [
          { "name": "save", "description": "Save the last Q&A as a knowledge card" },
          { "name": "useful", "description": "Mark the last answer as useful" },
          { "name": "notuseful", "description": "Mark the last answer as not useful" },
          { "name": "search", "description": "Search team knowledge (add keywords after /search)" },
          { "name": "list", "description": "List all knowledge cards" }
        ]
      }
    ],
    "languageModelChatProviders": [
      {
        "vendor": "monisave",
        "displayName": "MoniSave (Claude + thinking)",
        "managementCommand": "monisave.manage"
      }
    ],
    "commands": [
      { "command": "monisave.manage", "title": "MoniSave: Manage API Key" },
      { "command": "monisave.showSavings", "title": "MoniSave: Show savings" },
      { "command": "monisave.useFullEffortOnce", "title": "MoniSave: Use full effort for next message" },
      { "command": "monisave.selectEffortMode", "title": "MoniSave: Select effort mode" },
      { "command": "monisave.switchLanguage", "title": "MoniSave: Switch UI language (中文 / English)" },
      { "command": "monisave.saveCurrentQaAsKnowledge", "title": "MoniSave: Save current Q&A as knowledge" },
      { "command": "monisave.searchTeamKnowledge", "title": "MoniSave: Search team knowledge" },
      { "command": "monisave.markAnswerUseful", "title": "MoniSave: Mark answer useful" },
      { "command": "monisave.markAnswerNotUseful", "title": "MoniSave: Mark answer not useful" },
      { "command": "monisave.listKnowledgeCards", "title": "MoniSave: List knowledge cards" }
    ],
    "keybindings": [
      { "command": "monisave.selectEffortMode", "key": "ctrl+shift+e", "mac": "cmd+shift+e", "when": "editorTextFocus" }
    ]
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "test": "npm run build && node ./out/test/runTest.js"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0",
    "mocha": "^10.2.0",
    "@types/mocha": "^10.0.1",
    "chai": "^4.3.7",
    "@types/chai": "^4.3.0",
    "@vscode/test-electron": "^2.0.0",
    "glob": "^10.3.3"
  }
}
