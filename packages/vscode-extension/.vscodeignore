# Only include out/ (excluding test and maps), package.json, LICENSE
# Exclude everything by default, then exceptions are in vsce's include logic

# Source
src/**
tsconfig.json
.vscode/**

# Parent monorepo dirs - vsce must not follow these
../**
../../**

# Dependencies
node_modules/**

# Tests (out/test references ../../ paths that break vsce)
out/test/**

# Source maps and declaration maps (contain ../../ source references)
out/**/*.map
**/*.map

# Misc
.vscode-test/**
.vscode-test-user-data/**
coverage/**
*.log
*.vsix
